    "# S1-R1 — Food Waste Reduction: Three-Variant Rebound Analysis\n",
    "\n",
    "# Rebound variants:\n",
    "#   LOW     — Proportional reallocation across all non-food HH consumption\n",
    "#             (Donati 2020 default). Savings absorbed in noise of typical basket.\n",
    "#   CENTRAL — Empirical reallocation using DST Forbrugsundersøgelsen 2023\n",
    "#             COICOP shares for categories that absorb marginal income.\n",
    "#   HIGH    — Reallocation skewed toward high-GHG categories (flights,\n",
    "#             holidays, vehicles) per Girod & de Haan / Chakrabarti empirics.\n",
    "#\n",
    "# All three rebound variants assume 100% re-spending (full rebound).\n",
    "# The ZERO rebound case (no re-spending) is included as the reference bound.\n",
    "\n",
    "\n",
    "import time\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "# PART A: Primary intervention (identical across all rebound variants)\n",
    "\n",
    "kp = 0.30\n",
    "\n",
    "waste_categories = {\n",
    "    \"Avoidable processed animal-derived\": {\n",
    "        \"kt\": -0.082,\n",
    "        \"codes\": [\"C_PCAT\", \"C_PPIG\", \"C_PPLT\", \"C_POME\", \"C_DAIR\", \"C_FSHP\"],\n",
    "    },\n",
    "    \"Avoidable processed vegetable\": {\n",
    "        \"kt\": -0.105,\n",
    "        \"codes\": [\"C_OFOD\", \"C_SUGR\", \"C_RICE\", \"C_VOIL\"],\n",
    "    },\n",
    "    \"Avoidable unprocessed animal-derived\": {\n",
    "        \"kt\": -0.080,\n",
    "        \"codes\": [\"C_OANP\", \"C_FISH\"],\n",
    "    },\n",
    "    \"Avoidable unprocessed vegetable\": {\n",
    "        \"kt\": -0.298,\n",
    "        \"codes\": [\"C_FVEG\"],\n",
    "    },\n",
    "}\n",
    "\n",
    "# Collect food codes\n",
    "food_codes_all = []\n",
    "for cat_info in waste_categories.values():\n",
    "    for code in cat_info[\"codes\"]:\n",
    "        if code in code_to_local:\n",
    "            food_codes_all.append(code)\n",
    "\n",
    "food_local_indices = set(code_to_local[c] for c in food_codes_all)\n",
    "\n",
    "hh_col = dk_fd_start  # DK household final demand column\n",
    "\n",
    "# Apply primary demand reduction\n",
    "Y_reduced = Y.copy()\n",
    "total_saved = 0.0\n",
    "\n",
    "for cat_name, cat_info in waste_categories.items():\n",
    "    kt = cat_info[\"kt\"]\n",
    "    multiplier = 1 + (kt * kp)\n",
    "    for code in cat_info[\"codes\"]:\n",
    "        if code not in code_to_local:\n",
    "            continue\n",
    "        local_idx = code_to_local[code]\n",
    "        global_row = dk_offset + local_idx\n",
    "        baseline_val = Y[global_row, hh_col]\n",
    "        Y_reduced[global_row, hh_col] *= multiplier\n",
    "        total_saved += abs(Y_reduced[global_row, hh_col] - baseline_val)\n",
    "\n",
    "print(\" S1-R1: Food Waste Reduction — Rebound Analysis \\n\")\n",
    "print(f\"  kp = {kp:.0%}  |  Total saved: {total_saved:,.2f} M EUR\")\n",
    "\n",
    "\n",
    "# PART B: Define COICOP-to-EXIOBASE mapping for rebound allocation\n",
    "\n",
    "\n",
    "# DST Forbrugsundersøgelsen 2023 — \"Hele landet\" column (kr. pr. husstand)\n",
    "# Mapped to EXIOBASE product codes for the DK household Y column.\n",
    "\n",
    "\n",
    "# DST 2023 COICOP expenditure shares (kr/husstand → share of non-food total)\n",
    "# Exclude \"Food and non-alcoholic beverages\" (42,086) since that's\n",
    "# the impacted category. Total non-food = 374,247 - 42,086 = 332,161 kr.\n",
    "\n",
    "coicop_non_food = {\n",
    "    \"Alcoholic beverages and tobacco\":     6_298,\n",
    "    \"Clothing and footwear\":               11_900,\n",
    "    \"Housing, water, electricity etc.\":    118_853,\n",
    "    \"Housing and household services\":      19_137,\n",
    "    \"Health\":                              10_398,\n",
    "    \"Transport\":                           62_198,\n",
    "    \"Information and communication\":       16_229,\n",
    "    \"Leisure, Sports and Culture\":         25_268,\n",
    "    \"Education\":                            2_428,\n",
    "    \"Restaurants and hotels\":              24_470,\n",
    "    \"Insurance and financial services\":    21_696,\n",
    "    \"Personal care and miscellaneous\":     13_286,\n",
    "}\n",
    "\n",
    "total_non_food_dkk = sum(coicop_non_food.values())\n",
    "\n",
    "# COICOP → EXIOBASE product code mapping\n",
    "# Each COICOP category maps to one or more EXIOBASE sectors that represent\n",
    "# household purchases in that category. Weights within each COICOP group\n",
    "# are proportional to their baseline Y values (computed from the model).\n",
    "\n",
    "coicop_to_exiobase = {\n",
    "    \"Alcoholic beverages and tobacco\": [\"C_BEVR, C_TOBC\"],                  # Beverages + tobacco\n",
    "    \"Clothing and footwear\":            [\"C_GARM\", \"C_LETH\", \"C_TEXT\"],     # Garments, leather, textiles\n",
    "    \"Housing, water, electricity etc.\":   [\"C_POWW\", \"C_HWAT\", \"C_WATR\", \"C_REAL\" \"C_CONS\"],\n",
    "    \"Housing and household services\":      [\"C_TDRT\"],         # Retail/repair of HH goods\n",
    "    \"Health\":                              [\"C_CHEM\"],\n",
    "    \"Transport\":                           [\"C_MOTO\", \"C_TLND\", \"C_TAIR\", \"C_TDMO\", \"C_TRAI\"],  # Vehicles, land transport, maintenance\n",
    "    \"Information and communication\":    [\"C_COMP\", \"C_PTEL\"],  # Electronics, computers\n",
    "    \"Leisure, Sports and Culture\":         [\"C_PAPR\"],          # Paper/media as proxy\n",
    "    \"Education\":                            [\"C_EDUC\"],         # Education\n",
    "    \"Restaurants and hotels\":              [\"C_HORE\"],          # Hotels, restaurants, catering\n",
    "    \"Insurance and financial services\":    [\"C_FINT\", \"C_FINS\"],  # Financial services \n",
    "    \"Personal care and miscellaneous\":     [\"C_OSER\"],          # Other service (personal care products)\n",
    "}\n",
    "\n",
    "# PART C: Build rebound weight vectors for each variant\n",
    "# ═══════════════════════════════════════════════════════════════════════════════\n",
    "#\n",
    "# Each variant produces a weight vector over the 200 DK product sectors.\n",
    "# Weights sum to 1.0 and determine how saved euros are redistributed.\n",
    "\n",
    "\n",
    "def build_coicop_weights(coicop_shares_dict):\n",
    "    \"\"\"\n",
    "    Given a dict of {COICOP_category: target_share}, build a 200-element\n",
    "    weight vector over EXIOBASE local product indices for DK.\n",
    "    \n",
    "    Within each COICOP group, euros are split proportionally to baseline\n",
    "    Y values of the mapped EXIOBASE codes.\n",
    "    \"\"\"\n",
    "    weights = np.zeros(n_sectors)\n",
    "    \n",
    "    total_share = sum(coicop_shares_dict.values())\n",
    "    \n",
    "    for coicop_cat, target_share in coicop_shares_dict.items():\n",
    "        exio_codes = coicop_to_exiobase.get(coicop_cat, [])\n",
    "        if not exio_codes:\n",
    "            continue\n",
    "        \n",
    "        # Get baseline Y values for these codes\n",
    "        local_indices = []\n",
    "        baseline_vals = []\n",
    "        for code in exio_codes:\n",
    "            if code in code_to_local and code_to_local[code] not in food_local_indices:\n",
    "                li = code_to_local[code]\n",
    "                bv = Y[dk_offset + li, hh_col]\n",
    "                if bv > 0:\n",
    "                    local_indices.append(li)\n",
    "                    baseline_vals.append(bv)\n",
    "        \n",
    "        if not local_indices:\n",
    "            continue\n",
    "        \n",
    "        baseline_vals = np.array(baseline_vals)\n",
    "        intra_weights = baseline_vals / baseline_vals.sum()\n",
    "        \n",
    "        normalized_share = target_share / total_share\n",
    "        \n",
    "        for li, iw in zip(local_indices, intra_weights):\n",
    "            weights[li] += normalized_share * iw\n",
    "    \n",
    "    # Renormalize to sum to 1.0\n",
    "    if weights.sum() > 0:\n",
    "        weights /= weights.sum()\n",
    "    \n",
    "    return weights\n",
    "\n",
    "\n",
    "# ── LOW: Proportional to ALL non-food Y baseline (Donati default) ───────────\n",
    "\n",
    "dk_hh_baseline = Y[dk_offset:dk_offset + n_sectors, hh_col].copy()\n",
    "non_food_mask = np.ones(n_sectors, dtype=bool)\n",
    "for code in food_codes_all:\n",
    "    non_food_mask[code_to_local[code]] = False\n",
    "non_food_mask &= (dk_hh_baseline > 0)\n",
    "\n",
    "weights_low = np.zeros(n_sectors)\n",
    "weights_low[non_food_mask] = dk_hh_baseline[non_food_mask]\n",
    "weights_low /= weights_low.sum()\n",
    "\n",
    "\n",
    "# ── CENTRAL: DST Forbrugsundersøgelsen 2023 proportional shares ─────────────\n",
    "\n",
    "# Use actual COICOP non-food shares as-is\n",
    "weights_central = build_coicop_weights(coicop_non_food)\n",
    "\n",
    "\n",
    "# ── HIGH: Skewed toward high-GHG categories ─────────────────────────────────\n",
    "# Based on Girod & de Haan (2009) and Chakrabarti et al. evidence:\n",
    "# when high-income households gain marginal income, they disproportionately\n",
    "# spend on international travel, restaurants, vehicle purchases.\n",
    "# We inrease the weight on transport, restaurants/hotels, and fritid/kultur,\n",
    "\n",
    "\n",
    "coicop_high_ghg = {\n",
    "    \"Alcoholic beverages and tobacco\":     6_298 * 1.0,   # neutral\n",
    "    \"Clothing and footwear\":               11_900 * 1.0,   # neutral\n",
    "    \"Housing, water, electricity etc.\":    118_853 * 1.0,   # neutral\n",
    "    \"Housing and household services\":     19_137 * 1.0,   # neutral\n",
    "    \"Health\":                             10_398 * 1.0,   # neutral\n",
    "    \"Transport\":                           62_198 * 3.0,   # strongly increased — flights, vehicles\n",
    "    \"Information and communication\":        16_229 * 1.0,   # neutral\n",
    "    \"Leisure, sports and culture\":           25_268 * 2.0,   # doubled — leisure spending\n",
    "    \"Education\":                         2_428 * 1.0,   # neutral\n",
    "    \"Restaurants and hotels\":            24_470 * 3.0,   # tripled — dining out, holidays\n",
    "    \"Insurance and financial services\": 21_696 * 1.0,   # neutral\n",
    "    \"Personal care etc.\":                 13_286 * 2.0,   # increased — more spending on personal care, luxury goods\n",
    "}\n",
    "\n",
    "weights_high = build_coicop_weights(coicop_high_ghg)\n",
    "\n",
    "\n",
    "# Report rebound profiles\n",
    "\n",
    "print(\"\\n Rebound Allocation Profiles\\n\")\n",
    "\n",
    "def report_profile(weights, label):\n",
    "    print(f\"  ── {label} ──\")\n",
    "    entries = []\n",
    "    for li in range(n_sectors):\n",
    "        if weights[li] > 0.005:  # only show > 0.5%\n",
    "            code = product_ref.loc[li, \"product_synonym\"]\n",
    "            name = product_ref.loc[li, \"product_name\"][:40]\n",
    "            eur = total_saved * weights[li]\n",
    "            entries.append((weights[li], code, name, eur))\n",
    "    entries.sort(reverse=True)\n",
    "    for share, code, name, eur in entries[:12]:\n",
    "        print(f\"    {code:<10} {name:<40} {share:>6.1%}  {eur:>8.1f} M€\")\n",
    "    print()\n",
    "\n",
    "report_profile(weights_low, \"LOW (Donati proportional)\")\n",
    "report_profile(weights_central, \"CENTRAL (DST Forbrugsundersøgelsen 2023)\")\n",
    "report_profile(weights_high, \"HIGH (GHG-skewed: transport, holidays, dining)\")\n",
    "\n",
    "\n",
    "# PART D: Compute results for all variants\n",
    "\n",
    "\n",
    "variants = {\n",
    "    \"Zero (no rebound)\": {\"weights\": None,           \"frac\": 0.0},\n",
    "    \"Low (Donati)\":      {\"weights\": weights_low,     \"frac\": 1.0},\n",
    "    \"Central (DST)\":     {\"weights\": weights_central,  \"frac\": 1.0},\n",
    "    \"High (GHG-skewed)\": {\"weights\": weights_high,     \"frac\": 1.0},\n",
    "}\n",
    "\n",
    "# Baseline\n",
    "f_hh_base = Y[:, hh_col]\n",
    "x_cb_base = L @ f_hh_base\n",
    "cb_base = (s_co2eq * x_cb_base).sum() / 1e6\n",
    "cb_dk_base = (s_co2eq[dk_idx] * x_cb_base[dk_idx]).sum() / 1e6\n",
    "cb_abroad_base = cb_base - cb_dk_base\n",
    "terr_base = (s_co2eq[dk_idx] * x[dk_idx]).sum() / 1e6\n",
    "\n",
    "results = {}\n",
    "\n",
    "for vname, vconfig in variants.items():\n",
    "    Y_v = Y_reduced.copy()\n",
    "    \n",
    "    # Apply rebound reallocation\n",
    "    if vconfig[\"weights\"] is not None and vconfig[\"frac\"] > 0:\n",
    "        realloc = total_saved * vconfig[\"frac\"]\n",
    "        for li in range(n_sectors):\n",
    "            if vconfig[\"weights\"][li] > 0:\n",
    "                Y_v[dk_offset + li, hh_col] += realloc * vconfig[\"weights\"][li]\n",
    "    \n",
    "    # Budget check\n",
    "    hh_baseline_total = Y[dk_offset:dk_offset + n_sectors, hh_col].sum()\n",
    "    hh_variant_total  = Y_v[dk_offset:dk_offset + n_sectors, hh_col].sum()\n",
    "    budget_delta = hh_variant_total - hh_baseline_total\n",
    "    \n",
    "    # Compute output (L unchanged)\n",
    "    f_v = Y_v.sum(axis=1)\n",
    "    x_v = L @ f_v\n",
    "    \n",
    "    # CB CO₂eq\n",
    "    f_hh_v = Y_v[:, hh_col]\n",
    "    x_cb_v = L @ f_hh_v\n",
    "    \n",
    "    cb_total  = (s_co2eq * x_cb_v).sum() / 1e6\n",
    "    cb_dk     = (s_co2eq[dk_idx] * x_cb_v[dk_idx]).sum() / 1e6\n",
    "    cb_abroad = cb_total - cb_dk\n",
    "    \n",
    "    # Territorial\n",
    "    terr_dk = (s_co2eq[dk_idx] * x_v[dk_idx]).sum() / 1e6\n",
    "    \n",
    "    results[vname] = {\n",
    "        \"budget_delta\": budget_delta,\n",
    "        \"terr_dk\":      terr_dk,\n",

    "# Remove duplicates from lists\n",
    "\n",
    "def unique_in_order(values: list[str]) -> list[str]:\n",
    "    seen: set[str] = set()\n",
    "    ordered: list[str] = []\n",
    "    for value in values:\n",
    "        if value not in seen:\n",
    "            seen.add(value)\n",
    "            ordered.append(value)\n",
    "    return ordered"
   ]

    "    \"Education\":         {\"avg\":  1_812, \"low\":  1_108, \"high\":  3_970},\n",
    "    \"Restaurants_hotels\": {\"avg\": 21_694, \"low\":  8_152, \"high\": 39_769},\n",
    "    \"Insurance_finance\": {\"avg\": 18_156, \"low\":  5_777, \"high\": 30_650},\n",
    "    \"Personal_care\":     {\"avg\": 13_095, \"low\":  5_298, \"high\": 22_814},\n",
    "}\n",
    "\n",
    "\n",
    "# PART D: Build rebound weight vectors\n",
    "\n",
    "\n",
    "def build_coicop_weights(income_group):\n",
    "    \"\"\"\n",
    "    Build weight vector for rebound reallocation.\n",
    "    \n",
    "    Args:\n",
    "        income_group: \"avg\", \"low\", or \"high\" — selects column from FU15 data.\n",
    "    \n",
    "    Returns:\n",
    "        np.ndarray of shape (n_sectors,) summing to 1.0\n",
    "    \n",
    "    Logic:\n",
    "        1. For each COICOP category, compute its share of total non-food spending\n",
    "           for the chosen income group.\n",
    "        2. Map that COICOP share to the corresponding EXIOBASE codes.\n",
    "        3. Within each COICOP group, split euros across EXIOBASE codes\n",
    "           proportionally to their baseline household Y values.\n",
    "        4. Renormalize so all weights sum to 1.0.\n",
    "    \"\"\"\n",
    "    weights = np.zeros(n_sectors)\n",
    "    \n",
    "    # Step 1: Get spending amounts for this income group\n",
    "    spending = {cat: vals[income_group] for cat, vals in coicop_spending.items()}\n",
    "    total_nonfood = sum(spending.values())\n",
    "    \n",
    "    for coicop_cat, dkk_amount in spending.items():\n",
    "        # Step 2: Get mapped EXIOBASE codes\n",
    "        exio_codes = coicop_to_exiobase.get(coicop_cat, [])\n",
    "        if not exio_codes:\n",
    "            continue\n",
    "        \n",
    "        # Step 3: Get baseline Y values for these codes\n",
    "        local_indices = []\n",
    "        baseline_vals = []\n",
    "        for code in exio_codes:\n",
    "            if code in code_to_local:\n",
    "                li = code_to_local[code]\n",
    "                bv = Y[dk_offset + li, hh_col]\n",
    "                if bv > 0:\n",
    "                    local_indices.append(li)\n",
    "                    baseline_vals.append(bv)\n",
    "        \n",
    "        if not local_indices:\n",
    "            continue\n",
    "        \n",
    "        # COICOP share for this income group\n",
    "        coicop_share = dkk_amount / total_nonfood\n",
    "        \n",
    "        # Split within EXIOBASE codes proportionally to baseline Y\n",
    "        baseline_vals = np.array(baseline_vals)\n",
    "        intra_weights = baseline_vals / baseline_vals.sum()\n",
    "        \n",
    "        for li, iw in zip(local_indices, intra_weights):\n",
    "            weights[li] += coicop_share * iw\n",
    "    \n",
    "    # Step 4: Renormalize accounts for the dropped Education category\n",
    "    if weights.sum() > 0:\n",
    "        weights /= weights.sum()\n",
    "    \n",
    "    return weights\n",
    "\n",
    "\n",
    "# Build the three weight vectors\n",
    "weights_low     = build_coicop_weights(\"low\")\n",
    "weights_central = build_coicop_weights(\"avg\")\n",
    "weights_high    = build_coicop_weights(\"high\")\n",
    "\n",
    "# Report rebound profiles\n",
    "\n",
    "print(\"\\n═══ Rebound Allocation Profiles ═══\\n\")\n",
    "\n",
    "# Print COICOP-level summary for each variant\n",
    "print(f\"  {'COICOP category':<25} {'Low':>8} {'Central':>8} {'High':>8}\")\n",
    "print(\"  \" + \"─\" * 52)\n",
    "\n",
    "for cat in coicop_spending:\n",
    "    low_dkk  = coicop_spending[cat][\"low\"]\n",
    "    avg_dkk  = coicop_spending[cat][\"avg\"]\n",
    "    high_dkk = coicop_spending[cat][\"high\"]\n",
    "    \n",
    "    low_total  = sum(v[\"low\"]  for v in coicop_spending.values())\n",
    "    avg_total  = sum(v[\"avg\"]  for v in coicop_spending.values())\n",
    "    high_total = sum(v[\"high\"] for v in coicop_spending.values())\n",
    "    \n",
    "    l_pct = 100 * low_dkk  / low_total\n",
    "    a_pct = 100 * avg_dkk  / avg_total\n",
    "    h_pct = 100 * high_dkk / high_total\n",
    "    \n",
    "    has_codes = len(coicop_to_exiobase.get(cat, [])) > 0\n",
    "    flag = \"\" if has_codes else \"  (no EXIO codes)\"\n",
    "    \n",
    "    print(f\"  {cat:<25} {l_pct:>7.1f}% {a_pct:>7.1f}% {h_pct:>7.1f}%{flag}\")\n",
    "\n",
    "# Print EXIOBASE-level detail\n",
    "def report_profile(weights, label):\n",
    "    print(f\"\\n  ── {label} ──\")\n",
    "    entries = []\n",
    "    for li in range(n_sectors):\n",
    "        if weights[li] > 0.001:\n",
    "            code = product_ref.loc[li, \"product_synonym\"]\n",
    "            name = product_ref.loc[li, \"product_name\"][:40]\n",
    "            eur = total_saved * weights[li]\n",
    "            entries.append((weights[li], code, name, eur))\n",
    "    entries.sort(reverse=True)\n",
    "    for share, code, name, eur in entries[:15]:\n",
    "        print(f\"    {code:<10} {name:<40} {share:>6.1%}  {eur:>8.1f} M€\")\n",
    "\n",
    "report_profile(weights_low, \"LOW (FU15 low-income)\")\n",
    "report_profile(weights_central, \"CENTRAL (FU15 average)\")\n",
    "report_profile(weights_high, \"HIGH (FU15 high-income)\")\n",
    "\n",
    "# Verify weights sum to 1.0\n",
    "print(f\"\\n  Weight sums: Low={weights_low.sum():.4f}, \"\n",
    "      f\"Central={weights_central.sum():.4f}, \"\n",
    "      f\"High={weights_high.sum():.4f}\")\n",
    "\n",
    "# PART E: Compute results for all variants\n",
    "\n",
    "variant_configs = {\n",
    "    \"Zero\":    {\"weights\": None,            \"frac\": 0.0},\n",
    "    \"Low\":     {\"weights\": weights_low,     \"frac\": 1.0},\n",
    "    \"Central\": {\"weights\": weights_central, \"frac\": 1.0},\n",
    "    \"High\":    {\"weights\": weights_high,    \"frac\": 1.0},\n",
    "}\n",
    "\n",
    "# Baseline values\n",
    "f_hh_base    = Y[:, hh_col]\n",
    "x_cb_base    = L @ f_hh_base\n",
    "cb_base      = (s_co2eq * x_cb_base).sum() / 1e6\n",
    "cb_dk_base   = (s_co2eq[dk_idx] * x_cb_base[dk_idx]).sum() / 1e6\n",
    "cb_abroad_base = cb_base - cb_dk_base\n",
    "terr_base    = (s_co2eq[dk_idx] * x[dk_idx]).sum() / 1e6\n",
    "\n",
    "results = {}\n",
    "\n",
    "for vname, vconfig in variant_configs.items():\n",
    "    Y_v = Y_reduced.copy()\n",
    "    \n",
    "    # Apply rebound reallocation\n",
    "    if vconfig[\"weights\"] is not None and vconfig[\"frac\"] > 0:\n",
    "        realloc = total_saved * vconfig[\"frac\"]\n",
    "        for li in range(n_sectors):\n",
    "            if vconfig[\"weights\"][li] > 0:\n",
    "                Y_v[dk_offset + li, hh_col] += realloc * vconfig[\"weights\"][li]\n",
    "    \n",
    "    # Budget check\n",
    "    hh_baseline_total = Y[dk_offset:dk_offset + n_sectors, hh_col].sum()\n",
    "    hh_variant_total  = Y_v[dk_offset:dk_offset + n_sectors, hh_col].sum()\n",
    "    budget_delta = hh_variant_total - hh_baseline_total\n",
    "    \n",
    "    # Compute output (L unchanged — only Y modified)\n",
    "    f_v = Y_v.sum(axis=1)\n",
    "    x_v = L @ f_v\n",
    "    \n",
    "    # CB CO₂eq\n",
    "    f_hh_v = Y_v[:, hh_col]\n",
    "    x_cb_v = L @ f_hh_v\n",
    "    \n",
    "    cb_total  = (s_co2eq * x_cb_v).sum() / 1e6\n",
    "    cb_dk     = (s_co2eq[dk_idx] * x_cb_v[dk_idx]).sum() / 1e6\n",
    "    cb_abroad = cb_total - cb_dk\n",
    "    \n",
    "    # Territorial\n",
    "    terr_dk = (s_co2eq[dk_idx] * x_v[dk_idx]).sum() / 1e6\n",
    "    \n",
    "    results[vname] = {\n",
    "        \"budget_delta\": budget_delta,\n",
    "        \"terr_dk\":      terr_dk,\n",
    "        \"cb_total\":     cb_total,\n",
    "        \"cb_dk\":        cb_dk,\n",
    "        \"cb_abroad\":    cb_abroad,\n",
    "    }\n",
    "\n",
    "# PART F: Results tables\n",
    "\n",
    "DK_POP = 6_000_000  # Average population in 2026 according to DST\n",
    "\n",
    "vnames = [\"Zero\", \"Low\", \"Central\", \"High\"]\n",
    "\n",
    "print(\"\\n═══ S1-R1 Rebound Results — CO₂eq ═══\\n\")\n",
    "\n",
    "# Absolute changes\n",
    "print(f\"{'Metric':<30} {'Baseline':>10} {'Zero':>10} {'Low':>10} {'Central':>10} {'High':>10}\")\n",
    "print(\"─\" * 82)\n",
    "\n",
    "baselines = {\n",
    "    \"terr_dk\": terr_base, \"cb_total\": cb_base,\n",
    "    \"cb_dk\": cb_dk_base, \"cb_abroad\": cb_abroad_base,\n",
    "}\n",
    "\n",
    "for metric, label in [\n",
    "    (\"terr_dk\",   \"Territorial (kt)\"),\n",
    "    (\"cb_total\",  \"CB Total (kt)\"),\n",
    "    (\"cb_dk\",     \"CB DK (kt)\"),\n",
    "    (\"cb_abroad\", \"CB Abroad (kt)\"),\n",
    "]:\n",
    "    b = baselines[metric]\n",
    "    print(f\"{label:<30} {b:>10,.1f}\", end=\"\")\n",
    "    for v in vnames:\n",
    "        d = results[v][metric] - b\n",
    "        print(f\" {d:>+10,.2f}\", end=\"\")\n",
    "    print()\n",
    "\n",
    "# Budget check\n",
    "print(f\"\\n{'Budget Δ (M EUR)':<30} {'—':>10}\", end=\"\")\n",
    "for v in vnames:\n",
    "    print(f\" {results[v]['budget_delta']:>+10,.2f}\", end=\"\")\n",
    "print()\n",
    "\n",
    "# Percentage changes\n",
    "print(f\"\\n{'Metric':<30} {'Zero %':>10} {'Low %':>10} {'Central %':>10} {'High %':>10}\")\n",
    "print(\"─\" * 72)\n",
    "\n",
    "for metric, label in [\n",
    "    (\"terr_dk\",   \"Territorial\"),\n",
    "    (\"cb_total\",  \"CB Total\"),\n",
    "    (\"cb_dk\",     \"CB DK\"),\n",
    "    (\"cb_abroad\", \"CB Abroad\"),\n",
    "]:\n",
    "    b = baselines[metric]\n",
    "    print(f\"{label:<30}\", end=\"\")\n",
    "    for v in vnames:\n",
    "        pct = 100 * (results[v][metric] - b) / b\n",
    "        print(f\" {pct:>+10.3f}%\", end=\"\")\n",
    "    print()\n",
    "\n",
    "# Per capita\n",
    "print(f\"\\n═══ Per Capita ═══\\n\")\n",
    "print(f\"  Baseline: {cb_base * 1e3 / DK_POP:>8.2f} t CO₂eq/cap\\n\")\n",

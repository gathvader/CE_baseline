    "colors_list = [c[v] for v in vnames]\n",
    "shorts_list = [short[v] for v in vnames]\n",
    "\n",
    "# Plot 1: CB CO₂eq change\n",
    "ax = axes[0]\n",
    "deltas = [results[v][\"cb_total\"] - cb_base for v in vnames]\n",

    "\n",
    "# Mitigation retained\n",
    "print(f\"\\n═══ Mitigation Retention ═══\\n\")\n",
    "zero_saving = abs(results[\"Zero\"][\"cb_total\"] - cb_base)\n",
    "print(f\"  Zero-rebound saving (reference): {zero_saving:,.2f} kt\\n\")\n",
    "for v in [\"Low\", \"Central\", \"High\"]:\n",
    "    saving = cb_base - results[v][\"cb_total\"]\n",
    "    retained = 100 * saving / zero_saving if zero_saving > 0 else 0\n",
    "    eroded = 100 - retained\n",
    "    print(f\"  {v:<12s}  saving: {saving:>+8.2f} kt  retained: {retained:>5.1f}%  eroded: {eroded:>5.1f}%\")\n",

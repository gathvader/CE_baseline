    "import time\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "# PART A: Primary intervention (identical across all rebound variants)\n",
    "\n",
    "kp = 0.30\n",
    "\n",
    "waste_categories = {\n",
    "    \"Avoidable processed animal-derived\": {\n",
    "        \"kt\": -0.082,\n",
    "        \"codes\": [\"C_PCAT\", \"C_PPIG\", \"C_PPLT\", \"C_POME\", \"C_DAIR\", \"C_FSHP\"],\n",
    "    },\n",
    "    \"Avoidable processed vegetable\": {\n",
    "        \"kt\": -0.105,\n",
    "        \"codes\": [\"C_OFOD\", \"C_SUGR\", \"C_RICE\", \"C_VOIL\"],\n",
    "    },\n",
    "    \"Avoidable unprocessed animal-derived\": {\n",
    "        \"kt\": -0.080,\n",
    "        \"codes\": [\"C_OANP\", \"C_FISH\"],\n",
    "    },\n",
    "    \"Avoidable unprocessed vegetable\": {\n",
    "        \"kt\": -0.298,\n",
    "        \"codes\": [\"C_FVEG\"],\n",
    "    },\n",
    "}\n",
    "\n",
    "# Collect food codes\n",
    "food_codes_all = []\n",
    "for cat_info in waste_categories.values():\n",
    "    for code in cat_info[\"codes\"]:\n",
    "        if code in code_to_local:\n",
    "            food_codes_all.append(code)\n",
    "\n",
    "food_local_indices = set(code_to_local[c] for c in food_codes_all)\n",
    "\n",
    "hh_col = dk_fd_start  # DK household final demand column\n",
    "\n",
    "# Apply primary demand reduction\n",
    "Y_reduced = Y.copy()\n",
    "total_saved = 0.0\n",
    "\n",
    "for cat_name, cat_info in waste_categories.items():\n",
    "    kt = cat_info[\"kt\"]\n",
    "    multiplier = 1 + (kt * kp)\n",
    "    for code in cat_info[\"codes\"]:\n",
    "        if code not in code_to_local:\n",
    "            continue\n",
    "        local_idx = code_to_local[code]\n",
    "        global_row = dk_offset + local_idx\n",
    "        baseline_val = Y[global_row, hh_col]\n",
    "        Y_reduced[global_row, hh_col] *= multiplier\n",
    "        total_saved += abs(Y_reduced[global_row, hh_col] - baseline_val)\n",
    "\n",
    "print(\"═══ S1-R1: Food Waste Reduction — Rebound Analysis ═══\\n\")\n",
    "print(f\"  kp = {kp:.0%}  |  Total saved: {total_saved:,.2f} M EUR\")\n",
    "\n",
    "\n",
    "# PART B: COICOP-to-EXIOBASE mapping\n",
    "\n",
    "\n",
    "# Validated mapping — only codes with Y_hh > 0 are included.\n",
    "# Codes with zero household demand are excluded (marked in comments).\n",
    "\n",
    "# Source: DST FU15 2024 (Statistikbanken), COICOP classification.\n",
    "\n",
    "coicop_to_exiobase = {\n",
    "    \"Alcohol_tobacco\":    [\"C_BEVR\"],                                        # C_TOBC excluded (Y_hh = 0)\n",
    "    \"Clothing_footwear\":  [\"C_GARM\", \"C_LETH\"],                             # Wearing apparel + leather\n",
    "    \"Housing_utilities\":  [\"C_REAL\", \"C_CONS\", \"C_WATR\", \"C_HWAT\",\n",
    "                           \"C_POWW\", \"C_GASD\"],                             # All have Y_hh > 0\n",
    "    \"Furnishings_HH\":    [\"C_TDRT\", \"C_FURN\"],                             # Retail trade + furniture\n",
    "    \"Health\":            [\"C_CHEM\"],                                         # C_HEAL excluded (Y_hh = 0)\n",
    "    \"Transport\":         [\"C_TAUX\", \"C_TAIR\", \"C_TLND\", \"C_TDFU\",\n",
    "                           \"C_TDMO\", \"C_MOTO\"],                             # C_TRAI excluded (Y_hh = 0)\n",
    "    \"Info_comms\":        [\"C_COMP\", \"C_OFMA\"],                              # C_PTEL, C_RATV, C_ELMA excluded (Y_hh = 0)\n",
    "    \"Recreation\":        [\"C_RECR\"],                                         # Recreational services\n",
    "    \"Education\":         [],                                                 # C_EDUC excluded (Y_hh = 0) - this means 0.6% share lost, but its small\n",
    "    \"Restaurants_hotels\": [\"C_HORE\"],                                        # Hotels & restaurants\n",
    "    \"Insurance_finance\": [\"C_FAUX\", \"C_FINS\", \"C_FINT\"],                    # All financial services\n",
    "    \"Personal_care\":     [\"C_OSER\"],                                         # C_MEIN excluded (Y_hh = 0)\n",
    "}\n",
    "\n",
    "\n",
    "# PART C: FU15 income group spending (DKK per household, 2024)\n",
    "\n",
    "\n",
    "# Low income:  below 250,000 DKK total income\n",
    "# High income: above 1,000,000 DKK total income\n",
    "# Food category excluded — only non-food COICOP groups used for rebound.\n",
    "\n",
    "\n",
    "#                                         Average    Low     High\n",
    "coicop_spending = {\n",
    "    \"Alcohol_tobacco\":    {\"avg\":  5_524, \"low\":  2_890, \"high\":  8_494},\n",
    "    \"Clothing_footwear\":  {\"avg\": 12_657, \"low\":  4_548, \"high\": 21_860},\n",
    "    \"Housing_utilities\":  {\"avg\": 102_715,\"low\": 57_691, \"high\": 144_889},\n",
    "    \"Furnishings_HH\":    {\"avg\": 17_956, \"low\":  7_194, \"high\": 28_981},\n",
    "    \"Health\":            {\"avg\":  9_287, \"low\":  4_260, \"high\": 12_216},\n",
